     """
+    # A KUR updates a *specific* certificate, so the request subject must match
+    # the certificate being updated (RFC 9483 Section 4.1.3). When a `cert` is
+    # supplied, let its subject drive the CertTemplate instead of forcing the
+    # hardcoded default — otherwise CAs that key the device/identity off the
+    # subject look up the wrong certificate. Only fall back to the historic
+    # default when neither a cert nor an explicit common_name is given.
+    if common_name is None and cert is None:
+        common_name = "CN=Hans Mustermann"
