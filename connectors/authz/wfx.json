[
  {
    "name": "Job Manager",
    "description": "Siemens wfx (Workflow Executor) REST API v1.1 — full route mapping for Envoy ext_authz. Base paths: /api/wfx/nbi/v1, /api/wfx/sbi/v1",
    "groups": [
      {
        "name": "Mgmt NBI System",
        "routes": [
          {
            "name": "health-read",
            "methods": ["GET"],
            "path": "/api/wfx/nbi/v1/health",
            "match_type": "exact",
            "action": "nbi-health-read"
          },
          {
            "name": "version-read",
            "methods": ["GET"],
            "path": "/api/wfx/nbi/v1/version",
            "match_type": "exact",
            "action": "nbi-version-read"
          }
        ]
      },
      {
        "name": "Mgmt NBI Workflows",
        "routes": [
          {
            "name": "workflow-list",
            "methods": ["GET"],
            "path": "/api/wfx/nbi/v1/workflows",
            "match_type": "exact",
            "action": "nbi-workflow-list"
          },
          {
            "name": "workflow-create",
            "methods": ["POST"],
            "path": "/api/wfx/nbi/v1/workflows",
            "match_type": "exact",
            "action": "nbi-workflow-create"
          },
          {
            "name": "workflow-read",
            "methods": ["GET"],
            "path": "^/api/wfx/nbi/v1/workflows/[^/]+$",
            "match_type": "regex",
            "action": "nbi-workflow-read"
          },
          {
            "name": "workflow-delete",
            "methods": ["DELETE"],
            "path": "^/api/wfx/nbi/v1/workflows/[^/]+$",
            "match_type": "regex",
            "action": "nbi-workflow-delete"
          }
        ]
      },
      {
        "name": "Mgmt NBI Jobs",
        "routes": [
          {
            "name": "job-list",
            "methods": ["GET"],
            "path": "/api/wfx/nbi/v1/jobs",
            "match_type": "exact",
            "action": "nbi-job-list"
          },
          {
            "name": "job-create",
            "methods": ["POST"],
            "path": "/api/wfx/nbi/v1/jobs",
            "match_type": "exact",
            "action": "nbi-job-create"
          },
          {
            "name": "job-events",
            "methods": ["GET"],
            "path": "/api/wfx/nbi/v1/jobs/events",
            "match_type": "exact",
            "action": "nbi-job-events"
          },
          {
            "name": "job-status-read",
            "methods": ["GET"],
            "path": "^/api/wfx/nbi/v1/jobs/[^/]+/status$",
            "match_type": "regex",
            "action": "nbi-job-status-read"
          },
          {
            "name": "job-status-update",
            "methods": ["PUT"],
            "path": "^/api/wfx/nbi/v1/jobs/[^/]+/status$",
            "match_type": "regex",
            "action": "nbi-job-status-update"
          },
          {
            "name": "job-definition-read",
            "methods": ["GET"],
            "path": "^/api/wfx/nbi/v1/jobs/[^/]+/definition$",
            "match_type": "regex",
            "action": "nbi-job-definition-read"
          },
          {
            "name": "job-definition-update",
            "methods": ["PUT"],
            "path": "^/api/wfx/nbi/v1/jobs/[^/]+/definition$",
            "match_type": "regex",
            "action": "nbi-job-definition-update"
          },
          {
            "name": "job-tags-read",
            "methods": ["GET"],
            "path": "^/api/wfx/nbi/v1/jobs/[^/]+/tags$",
            "match_type": "regex",
            "action": "nbi-job-tags-read"
          },
          {
            "name": "job-tags-add",
            "methods": ["POST"],
            "path": "^/api/wfx/nbi/v1/jobs/[^/]+/tags$",
            "match_type": "regex",
            "action": "nbi-job-tags-add"
          },
          {
            "name": "job-tags-delete",
            "methods": ["DELETE"],
            "path": "^/api/wfx/nbi/v1/jobs/[^/]+/tags$",
            "match_type": "regex",
            "action": "nbi-job-tags-delete"
          },
          {
            "name": "job-read",
            "methods": ["GET"],
            "path": "^/api/wfx/nbi/v1/jobs/[^/]+$",
            "match_type": "regex",
            "action": "nbi-job-read"
          },
          {
            "name": "job-delete",
            "methods": ["DELETE"],
            "path": "^/api/wfx/nbi/v1/jobs/[^/]+$",
            "match_type": "regex",
            "action": "nbi-job-delete"
          }
        ]
      },
      {
        "name": "Device SBI System",
        "routes": [
          {
            "name": "health-read",
            "methods": ["GET"],
            "path": "/api/wfx/sbi/v1/health",
            "match_type": "exact",
            "action": "sbi-health-read"
          },
          {
            "name": "version-read",
            "methods": ["GET"],
            "path": "/api/wfx/sbi/v1/version",
            "match_type": "exact",
            "action": "sbi-version-read"
          }
        ]
      },
      {
        "name": "Device SBI Workflows",
        "routes": [
          {
            "name": "workflow-list",
            "methods": ["GET"],
            "path": "/api/wfx/sbi/v1/workflows",
            "match_type": "exact",
            "action": "sbi-workflow-list"
          },
          {
            "name": "workflow-read",
            "methods": ["GET"],
            "path": "^/api/wfx/sbi/v1/workflows/[^/]+$",
            "match_type": "regex",
            "action": "sbi-workflow-read"
          }
        ]
      },
      {
        "name": "Device SBI Jobs",
        "routes": [
          {
            "name": "job-list",
            "methods": ["GET"],
            "path": "/api/wfx/sbi/v1/jobs",
            "match_type": "exact",
            "action": "sbi-job-list",
            "constraints": [
              {
                "request": { "source": "query", "name": "clientId" },
                "equals_subject_attribute": "client_id"
              }
            ]
          },
          {
            "name": "job-events",
            "methods": ["GET"],
            "path": "/api/wfx/sbi/v1/jobs/events",
            "match_type": "exact",
            "action": "sbi-job-events",
            "constraints": [
              {
                "request": { "source": "query", "name": "clientIds" },
                "equals_subject_attribute": "client_id"
              }
            ]
          },
          {
            "name": "job-status-read",
            "methods": ["GET"],
            "path": "^/api/wfx/sbi/v1/jobs/[^/]+/status$",
            "match_type": "regex",
            "action": "sbi-job-status-read",
            "constraints": [
              {
                "request": { "source": "header", "name": "x-wfx-client-id" },
                "equals_subject_attribute": "client_id"
              }
            ]
          },
          {
            "name": "job-status-update",
            "methods": ["PUT"],
            "path": "^/api/wfx/sbi/v1/jobs/[^/]+/status$",
            "match_type": "regex",
            "action": "sbi-job-status-update",
            "constraints": [
              {
                "request": { "source": "json_body", "path": "$.clientId" },
                "equals_subject_attribute": "client_id"
              }
            ]
          },
          {
            "name": "job-definition-read",
            "methods": ["GET"],
            "path": "^/api/wfx/sbi/v1/jobs/[^/]+/definition$",
            "match_type": "regex",
            "action": "sbi-job-definition-read",
            "constraints": [
              {
                "request": { "source": "header", "name": "x-wfx-client-id" },
                "equals_subject_attribute": "client_id"
              }
            ]
          },
          {
            "name": "job-definition-update",
            "methods": ["PUT"],
            "path": "^/api/wfx/sbi/v1/jobs/[^/]+/definition$",
            "match_type": "regex",
            "action": "sbi-job-definition-update",
            "constraints": [
              {
                "request": { "source": "header", "name": "x-wfx-client-id" },
                "equals_subject_attribute": "client_id"
              }
            ]
          },
          {
            "name": "job-tags-read",
            "methods": ["GET"],
            "path": "^/api/wfx/sbi/v1/jobs/[^/]+/tags$",
            "match_type": "regex",
            "action": "sbi-job-tags-read",
            "constraints": [
              {
                "request": { "source": "header", "name": "x-wfx-client-id" },
                "equals_subject_attribute": "client_id"
              }
            ]
          },
          {
            "name": "job-read",
            "methods": ["GET"],
            "path": "^/api/wfx/sbi/v1/jobs/[^/]+$",
            "match_type": "regex",
            "action": "sbi-job-read",
            "constraints": [
              {
                "request": { "source": "header", "name": "x-wfx-client-id" },
                "equals_subject_attribute": "client_id"
              }
            ]
          }
        ]
      }
    ]
  }
]
